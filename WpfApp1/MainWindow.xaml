<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button Content="Button" HorizontalAlignment="Left" Margin="682,42,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="leftSet" HorizontalAlignment="Left" Margin="503,35,0,0" VerticalAlignment="Top" Width="120" RenderTransformOrigin="-0.933,3.228"/>
        <ComboBox Name="operation" HorizontalAlignment="Left" Margin="74,36,0,0" VerticalAlignment="Top" Width="120" RenderTransformOrigin="-0.561,0.112"/>
        <ComboBox Name="rightSet" HorizontalAlignment="Left" Margin="280,35,0,0" VerticalAlignment="Top" Width="120" RenderTransformOrigin="0.039,0.793"/>
        <ListBox Name="leftMembers" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="67,88,599,169" Width="NaN" Height="NaN" RenderTransformOrigin="0.455,0.689"/>
        <ListBox Name="rightMembers" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="503,88,171,169" Width="NaN" Height="NaN"/>
        <ListBox Name="resultSet" d:ItemsSource="{d:SampleData ItemCount=5}" RenderTransformOrigin="0.5,0.5" Margin="646,90,24,162" Width="NaN" Height="NaN">
            <ListBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="-0.355"/>
                    <RotateTransform/>
                    <TranslateTransform Y="-2.48"/>
                </TransformGroup>
            </ListBox.RenderTransform>
        </ListBox>

    </Grid>
</Window>
